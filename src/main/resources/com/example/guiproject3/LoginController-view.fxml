<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="596.0" prefWidth="581.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.guiproject3.LoginController">
    <children>
      <ImageView fitHeight="600.0" fitWidth="600.0" opacity="0.9" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../Images/purple.jpg" />
         </image>
      </ImageView>

        <!-- Login Page Container -->
        <AnchorPane fx:id="mainPane" opacity="0.85" prefHeight="500.0" prefWidth="470.0">
            <!-- Login Form -->
            <AnchorPane fx:id="loginPane" managed="true" prefHeight="600.0" prefWidth="600.0" style="-fx-border-color: #808080; -fx-border-width: 3px; -fx-border-radius: 2px;">
                <children>
                    <Label layoutX="201.0" layoutY="53.0" prefHeight="61.0" prefWidth="197.0" style="-fx-font-size: 35px; -fx-font-weight: bold; -fx-text-fill: white;" text="Login Page">
                  <font>
                     <Font name="Times New Roman Bold Italic" size="18.0" />
                  </font></Label>

                    <!-- Grid Layout for Form Fields -->
                    <GridPane hgap="10.0" layoutX="90.0" layoutY="153.0" prefHeight="259.0" prefWidth="419.0" vgap="20.0">
                        <children>
                     <Label prefHeight="5.0" prefWidth="160.0" style="-fx-text-fill: white;" text="Username:">
                        <font>
                           <Font name="Times New Roman Bold" size="24.0" />
                        </font>
                     </Label>
                     <TextField fx:id="loginUsernameField" promptText="Enter Username" style="-fx-border-color: blue; -fx-border-radius: 3px; -fx-border-width: 2px;" GridPane.columnIndex="2">
                        <tooltip>
                           <Tooltip text="Your unique username" />
                        </tooltip>
                        <font>
                           <Font name="Times New Roman Bold" size="18.0" />
                        </font>
                     </TextField>
                            <!-- Username Field -->
                            <Label prefHeight="5.0" prefWidth="160.0" style="-fx-text-fill: white;" text="UserEmail:" GridPane.rowIndex="1">
                                <font>
                                    <Font name="Times New Roman Bold" size="24.0" />
                                </font></Label>
                            <TextField fx:id="loginUserEmailField" promptText="Enter UserEmail" style="-fx-border-color: blue; -fx-border-radius: 3px; -fx-border-width: 2px;" GridPane.columnIndex="2" GridPane.rowIndex="1">
                                <tooltip>
                                    <Tooltip text="Your unique userEmail" />
                                </tooltip>
                                <font>
                                    <Font name="Times New Roman Bold" size="18.0" />
                                </font>
                            </TextField>

                            <!-- Login Password Field -->
                            <Label prefHeight="13.0" prefWidth="170.0" style="-fx-text-fill: white; -fx-font-weight: bold;" text="Password:" GridPane.rowIndex="2">
                                <font>
                                    <Font name="Times New Roman Bold Italic" size="24.0" />
                                </font>
                            </Label>
                            <PasswordField fx:id="loginPasswordField" managed="true" promptText="Enter Password" style="-fx-border-color: blue; -fx-border-radius: 2px; -fx-border-width: 2px;" visible="true" GridPane.columnIndex="2" GridPane.rowIndex="2">
                                <tooltip>
                                    <Tooltip text="Your secure password" />
                                </tooltip>
                                <font>
                                    <Font name="Times New Roman Bold" size="18.0" />
                                </font>
                            </PasswordField>

                            <TextField fx:id="loginPasswordVisibleField" managed="false" promptText="Enter Password" style="-fx-border-color: blue; -fx-border-radius: 2px; -fx-border-width: 2px;" visible="false" GridPane.columnIndex="2" GridPane.rowIndex="2" />

                            <!-- Show Password Checkbox for Login -->
                            <CheckBox fx:id="showLoginPasswordCheckBox" style="-fx-text-fill: white;" text="Show Password" GridPane.columnIndex="2" GridPane.halignment="RIGHT" GridPane.rowIndex="3" GridPane.valignment="TOP">
                                <font>
                                    <Font name="Times New Roman Bold" size="18.0" />
                                </font>
                            </CheckBox>


                            <!-- Remember Me Checkbox -->
                            <CheckBox fx:id="rememberMeCheckBox" onAction="#initialize" prefHeight="23.0" prefWidth="151.0" style="-fx-text-fill: white; -fx-font-weight: bold;" text="Remember Me" GridPane.halignment="LEFT" GridPane.rowIndex="3" GridPane.valignment="TOP">
                                <font>
                                    <Font name="Times New Roman Bold" size="18.0" />
                                </font></CheckBox>

                            <!-- Buttons -->
                            <Button onAction="#handleLogin" prefHeight="56.0" prefWidth="125.0" style="-fx-font-size: 25px; -fx-font-weight: bold; -fx-border-color: #808080; -fx-border-width: 2px; -fx-background-color: #4B0082; -fx-text-fill: white;" text="Sign-In" GridPane.halignment="CENTER" GridPane.rowIndex="5" GridPane.valignment="CENTER">
                                <font>
                                    <Font name="Times New Roman Bold Italic" size="24.0" />
                                </font></Button>
                            <Button alignment="TOP_RIGHT" onAction="#switchToSignup" prefHeight="56.0" prefWidth="132.0" style="-fx-font-size: 25px; -fx-font-weight: bold; -fx-border-color: #808080; -fx-border-width: 2px; -fx-background-color: #4B0082; -fx-text-fill: white;" text="Sign-up" GridPane.columnIndex="2" GridPane.halignment="CENTER" GridPane.rowIndex="5" GridPane.valignment="CENTER" />
                        </children>
                        <columnConstraints>
                            <ColumnConstraints maxWidth="157.33333333333334" minWidth="123.33333333333334" prefWidth="157.33333333333334" />
                            <ColumnConstraints maxWidth="36.66668701171875" minWidth="0.0" prefWidth="0.0" />
                            <ColumnConstraints maxWidth="241.33333333333334" minWidth="204.6666463216146" prefWidth="241.33333333333334" />
                        </columnConstraints>
                        <rowConstraints>
                     <RowConstraints maxHeight="31.999989827473957" minHeight="15.333333333333332" prefHeight="30.0" />
                            <RowConstraints maxHeight="31.999989827473957" minHeight="15.333333333333332" />
                            <RowConstraints maxHeight="45.33333333333333" minHeight="18.66667683919271" prefHeight="45.33333333333333" />
                            <RowConstraints maxHeight="37.33333333333333" minHeight="0.0" prefHeight="37.33333333333333" />
                            <RowConstraints maxHeight="51.99997965494791" minHeight="0.0" prefHeight="0.0" />
                            <RowConstraints maxHeight="50.0" minHeight="10.000020345052093" prefHeight="25.333333333333343" />
                        </rowConstraints>
                        <opaqueInsets>
                            <Insets />
                        </opaqueInsets>
                    </GridPane>

                    <!-- Forgot Password Link -->
                    <Label layoutX="197.0" layoutY="478.0" onMouseClicked="#handleForgotPassword" prefHeight="47.0" prefWidth="206.0" style="-fx-text-fill: white; -fx-border-width: 2px; -fx-font-size: 25px; -fx-underline: true;" text="Forgot Password?">
                  <font>
                     <Font size="18.0" />
                  </font></Label>
                </children>
            </AnchorPane>

            <!-- Signup Page (Hidden by default) -->
            <AnchorPane fx:id="signupPane" managed="false" opacity="0.91" prefHeight="500.0" prefWidth="500.0" style="-fx-border-width: 3px; -fx-border-radius: 2px;" visible="false">
                <children>
      
                                                                    <!-- Grid Layout for Signup Fields -->
                    <GridPane hgap="2.0" layoutX="50.0" layoutY="100.0" prefHeight="307.0" prefWidth="452.0" vgap="20.0">
                        <children>
                            <!-- Username Field -->
                            <Label prefHeight="36.0" prefWidth="183.0" style="-fx-border-radius: 2px; -fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-font-size: 19px;" text="Username:" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <font>
                                    <Font size="18.0" />
                                </font>
                     </Label>
                            <TextField fx:id="signupUsernameField" promptText="Enter Username" style="-fx-font-weight: bold;" GridPane.columnIndex="1">
                                <font>
                                    <Font size="18.0" />
                                </font>
                        <tooltip>
                           <Tooltip text="Enter a unique username (alphanumeric, 3-15 characters)" />
                        </tooltip>
                     </TextField>
      
                                                                            <!-- Email Field -->
                            <Label prefHeight="36.0" prefWidth="181.0" style="-fx-font-weight: bold; -fx-text-fill: #FFFFFF; -fx-font-size: 19px;" text="Email:" GridPane.rowIndex="1">
                                <font>
                                    <Font size="18.0" />
                                </font>
                     </Label>
                            <TextField fx:id="signupEmailField" promptText="Enter Email" style="-fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <font>
                                    <Font size="18.0" />
                                </font>
                        <tooltip>
                           <Tooltip text="Enter a valid email address (e.g., user@example.com" />
                        </tooltip>
                     </TextField>
      
                                                                            <!-- Signup Password Field -->
                            <Label prefHeight="36.0" prefWidth="182.0" style="-fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-font-size: 19px;" text="Password:" GridPane.rowIndex="2">
                                <font>
                                    <Font name="Times New Roman Bold" size="18.0" />
                                </font>
                     </Label>
                            <PasswordField fx:id="signupPasswordField" promptText="Enter Password" style="-fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                <font>
                                    <Font size="18.0" />
                                </font>
                        <tooltip>
                           <Tooltip text="8-20 chars, 1 uppercase, 1 lowercase, 1 digit, 1 special (!@#$%^&amp;*)." />
                        </tooltip>
                     </PasswordField>
      
                                                                            <!-- Confirm Password Field -->
                            <Label prefHeight="36.0" prefWidth="183.0" style="-fx-font-weight: bold; -fx-text-fill: #FFFFFF; -fx-font-size: 19px;" text="Confirm Password:" GridPane.rowIndex="3">
                                <font>
                                    <Font size="18.0" />
                                </font>
                     </Label>
                            <PasswordField fx:id="signupConfirmPasswordField" promptText="Confirm Password" style="-fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="3">
                                <font>
                                    <Font size="18.0" />
                                </font>
                        <tooltip>
                           <Tooltip text="Must match the above password" />
                        </tooltip>
                     </PasswordField>
                            <Button alignment="TOP_LEFT" onAction="#switchToLogin" prefHeight="0.0" prefWidth="213.0" style="-fx-font-size: 27px; -fx-font-weight: bold; -fx-background-color: #4B0082; -fx-text-fill: #FFFFFF; -fx-border-color: #808080; -fx-border-radius: 2px; -fx-border-width: 2px;" text="Back to Login" GridPane.columnIndex="1" GridPane.rowIndex="4" />
      
                                                                            <!-- Buttons -->
                            <Button cancelButton="true" onAction="#handleSignup" prefHeight="50.0" prefWidth="120.0" style="-fx-font-size: 25px; -fx-border-radius: 2px; -fx-border-width: 2px; -fx-font-weight: bold; -fx-background-color: #4B0082; -fx-text-fill: #FFFFFF; -fx-border-color: #808080;" text="Signup" GridPane.rowIndex="4">
                                <font>
                                    <Font size="21.0" />
                                </font>
                            </Button>
                        </children>
                        <columnConstraints>
                            <ColumnConstraints />
                            <ColumnConstraints />
                        </columnConstraints>
                        <rowConstraints>
                            <RowConstraints />
                            <RowConstraints />
                            <RowConstraints />
                            <RowConstraints />
                            <RowConstraints />
                        </rowConstraints>
                    </GridPane>
               <Label alignment="CENTER" prefHeight="95.0" prefWidth="600.0" style="-fx-text-fill: #FFFFFF; -fx-font-size: 40px; -fx-font-weight: bold;" text="   Signup">
                  <font>
                     <Font name="Times New Roman Bold" size="24.0" />
                  </font>
               </Label>
                </children>
            </AnchorPane>
        </AnchorPane>
    </children>
</StackPane>
